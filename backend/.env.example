# Server
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000
API_BASE_URL=http://localhost:5000

# Cluster
CLUSTER_WORKERS=0
# 0 = auto (use all CPU cores) - recommended for 1000+ concurrent users

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/qrbharat
MONGO_POOL_SIZE=50

# Redis (required for Socket.IO horizontal scaling, rate limiting & caching)
REDIS_URL=redis://127.0.0.1:6379

# JWT
JWT_ACCESS_SECRET=change_this_access_secret_super_long_random
JWT_REFRESH_SECRET=change_this_refresh_secret_super_long_random
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Cookies
COOKIE_DOMAIN=localhost

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# Bcrypt
BCRYPT_SALT_ROUNDS=10

# Short URL base (for dynamic QR redirect links)
SHORT_URL_BASE=https://qrb.in
