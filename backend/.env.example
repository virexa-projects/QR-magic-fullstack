# Server
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000
API_BASE_URL=http://192.168.0.114:5000/api/v1
GOOGLE_CLIENT_ID=5xxxxxxxxxxxxxxxxxxxx
# Cluster
CLUSTER_WORKERS=0
# 0 = auto (use all CPU cores) - recommended for 1000+ concurrent users

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/qrbharat
MONGO_POOL_SIZE=50

# Redis (required for Socket.IO horizontal scaling, rate limiting & caching)
REDIS_URL=redis://127.0.0.1:6379

# JWT
JWT_ACCESS_SECRET=change_this_access_secret_super_long_random
JWT_REFRESH_SECRET=change_this_refresh_secret_super_long_random
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Cookies
COOKIE_DOMAIN=localhost

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# Bcrypt
BCRYPT_SALT_ROUNDS=10

FRONTEND_URL=http://localhost:3000

#PAYPAL
PAYPAL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxx
PAYPAL_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxx
PAYPAL_MODE=sandbox                 # "sandbox" | "live"
INR_TO_USD_FALLBACK_RATE=0.012
PAYPAL_WEBHOOK_ID=your_webhook_id_here   # from PayPal Dashboard > Webhooks